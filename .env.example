# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=tradingcopilot
POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_ME
# Used by the backend to connect; must match the above credentials
DATABASE_URL=postgresql://trading:CHANGE_ME@db:5432/tradingcopilot

# ─── FastAPI ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ─── Market Data APIs ────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here

# ─── Alpaca Markets ──────────────────────────────────────────────────────────
# API credentials from https://alpaca.markets
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here
# Base URL: https://paper-api.alpaca.markets (paper) or https://api.alpaca.markets (live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Set to "true" for paper trading, "false" for live trading
ALPACA_PAPER=true

# ─── Email / SMTP Alerts ─────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your_smtp_password_here
